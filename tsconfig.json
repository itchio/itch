{
  "compilerOptions": {
    "target": "es2021",
    "moduleResolution": "bundler",
    "module": "esnext",
    "esModuleInterop": true,
    "jsx": "react-jsx",

    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    "paths": {
      "common/*": ["./src/common/*"],
      "renderer/*": ["./src/renderer/*"],
      "main/*": ["./src/main/*"],
      "vendor/*": ["./src/vendor/*"]
    },

    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "experimentalDecorators": true
  },
  "include": ["src/**/*", "typings/**/*"]
}
