  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/osx-sign": "^2.5.0",
    "@electron/packager": "^20.0.2",
    "@itchio/bob": "^2.1.0",
    "@types/classnames": "^2.2.11",
    "@types/debug": "^4.1.13",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.0.0",
    "@types/prop-types": "^15.7.3",
    "@types/react": "^17.0.80",
    "@types/react-dom": "^17.0.25",
    "@types/react-json-tree": "^0.6.11",
    "@types/react-redux": "^7.1.16",
    "@types/readable-stream": "^4.0.22",
    "@types/semver": "^7.3.4",
    "@types/split2": "^4.2.3",
    "@types/styled-components": "^5.1.36",
    "@types/underscore": "^1.13.0",
    "@types/vivus": "^0.4.3",
    "@types/which": "^3.0.4",
    "@types/yauzl": "^2.10.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^2.8.8",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "sync-butler": "cd ../butler && go run ./butlerd/generous ts ../itch/src/common/butlerd/messages.ts && cd ../itch && prettier --write src/common/butlerd/messages.ts",
    "sync-i18n": "node release/sync-i18n-strings.js",
    "start": "node develop.mjs",
    "codex": "codex -c 'mcp_servers.chrome-devtools.command=\"npx\"' -c 'mcp_servers.chrome-devtools.args=[\"chrome-devtools-mcp@latest\",\"--browser-url=http://127.0.0.1:9223\"]'",
    "compile": "cross-env NODE_ENV=production node build.mjs",
    "clean": "rm -rf artifacts dist prefix build .chromedriver *.log.txt",
    "integration-tests": "node release/test.js --detect-osarch",
    "ts-check": "npm run ts-check:app && npm run ts-check:release",
    "ts-check:app": "tsc -b",
    "ts-check:release": "tsc -p release",
    "ts-watch": "tsc -b --watch",
    "ts-watch:main": "tsc -p tsconfig.main.json --watch",
    "ts-watch:preload": "tsc -p tsconfig.preload.json --watch",
    "ts-watch:renderer": "tsc -p tsconfig.renderer.json --watch",
    "release": "node release/push-tag.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
