    "shell-quote": "^1.9.0",
    "split2": "^4.2.0",
    "styled-components": "^5.3.11",
    "systeminformation": "^5.31.13",
    "term-color": "^1.0.1",
    "triangulr": "^1.0.3",
    "underscore": "^1.12.0",
    "url": "^0.11.4",
    "uuid": "^14.0.1",
    "vivus": "^0.4.5",
    "which": "^6.0.1",
