    "react-sortable-hoc": "^1.11.0",
    "react-tabs": "^4.3.0",
    "redux": "^4.0.5",
    "redux-cli-logger": "^2.1.0",
    "redux-logger": "^3.0.6",
    "reselect": "^4.0.0",
